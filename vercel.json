{
  "version": 2,
  "outputDirectory": "web",
  "routes": [
    {
      "src": "^/docs/?$",
      "dest": "/docs/index.html"
    },
    {
      "src": "^/docs/(.+)$",
      "dest": "/docs/$1"
    },
    {
      "src": "^/assets/(.+)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": ".*",
      "dest": "/404.html",
      "status": 404
    }
  ]
}